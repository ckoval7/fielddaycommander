:80 {
	root * /app/public
	encode zstd gzip

	# Allow uploads up to 35MB (matches PHP post_max_size)
	request_body {
		max_size 35MB
	}

	route /app/* {
		reverse_proxy 127.0.0.1:8080 {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	php_server
}
