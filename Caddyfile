{$CADDY_SITE_ADDRESS::80} {
	root * {$APP_PATH:/var/www/fd-commander}/public
	encode zstd gzip

	# Allow uploads up to 35MB (matches PHP post_max_size)
	request_body {
		max_size 35MB
	}

	# Reverb WebSocket proxy — route block enforces top-to-bottom ordering
	# so reverse_proxy runs before php_server intercepts /app/* requests.
	route /app/* {
		reverse_proxy {$REVERB_SERVER_HOST:127.0.0.1}:{$REVERB_SERVER_PORT:8080} {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	php_server
}
