# ---------------------------------------------------------------
# Application Settings
# ---------------------------------------------------------------
# APP_NAME is shown in the browser title bar and email notifications.
APP_NAME="Field Day Commander"

# Environment: local, staging, production
APP_ENV=local

# Generated with: php artisan key:generate
APP_KEY=

# Set to false in production to hide detailed error pages.
APP_DEBUG=true

# The base URL for your installation (no trailing slash).
APP_URL=http://localhost

# Developer mode enables time travel, database reset tools, etc.
# WARNING: Never enable in production!
DEVELOPER_MODE=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Increase for better performance with the built-in PHP server.
# PHP_CLI_SERVER_WORKERS=4

# ---------------------------------------------------------------
# Octane / FrankenPHP (production)
# ---------------------------------------------------------------
# Uncomment these when deploying with Laravel Octane.
# OCTANE_SERVER=frankenphp
# OCTANE_WORKERS=auto
# OCTANE_MAX_REQUESTS=500

# Domain for Caddy/FrankenPHP (used by Caddyfile).
# DOMAIN=localhost

# Application path (used by Caddyfile for document root).
# APP_PATH=/var/www/fd-commander

# ---------------------------------------------------------------
# Password Hashing
# ---------------------------------------------------------------
# Higher values are more secure but slower. 12 is a good default.
BCRYPT_ROUNDS=12

# ---------------------------------------------------------------
# Logging
# ---------------------------------------------------------------
# "stack" combines multiple channels. See config/logging.php.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null

# Options: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=debug

# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------
# SQLite is the simplest option — no external server needed.
# For MySQL/PostgreSQL, uncomment and configure the lines below.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# ---------------------------------------------------------------
# Session
# ---------------------------------------------------------------
# Driver: file, cookie, database, redis, memcached, array
SESSION_DRIVER=database

# How long (in minutes) before an idle session expires.
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ---------------------------------------------------------------
# Services
# ---------------------------------------------------------------
# Broadcasting: log (default, no real-time), reverb, pusher, ably
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue: sync (immediate), database, redis, sqs
QUEUE_CONNECTION=database

# ---------------------------------------------------------------
# Cache
# ---------------------------------------------------------------
# Store: file, database, redis, memcached, array
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# ---------------------------------------------------------------
# Redis (only needed if using Redis for cache, queue, or session)
# ---------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------
# Mail
# ---------------------------------------------------------------
# Mailer: smtp, sendmail, mailgun, ses, postmark, log, array
# Use "log" for development — emails appear in storage/logs.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------
# AWS (only needed for S3 storage or SES email)
# ---------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------
# Vite / Frontend
# ---------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------
# Authentication & Security
# ---------------------------------------------------------------

# Two-Factor Authentication: required | optional | disabled
# "required" forces all users to set up 2FA before they can proceed.
# "optional" lets each user decide. "disabled" removes the option entirely.
2FA_MODE=optional

# Registration: open | approval_required | email_verification_required | disabled
# "open" allows anyone to register immediately.
# "approval_required" queues new accounts for admin approval.
# "email_verification_required" sends a verification link first.
# "disabled" closes registration entirely — admins create all accounts.
REGISTRATION_MODE=open

# Password Reset: email | admin_only | hybrid
# "email" sends a reset link. "admin_only" requires an admin to reset.
# "hybrid" allows either method.
PASSWORD_RESET_METHOD=hybrid

# Failed Login: lockout | progressive_delay
# "lockout" locks the account after LOCKOUT_THRESHOLD failures.
# "progressive_delay" adds increasing wait times between attempts.
FAILED_LOGIN_STRATEGY=progressive_delay

# Number of failed attempts before lockout or max delay kicks in.
LOCKOUT_THRESHOLD=5

# Minutes an account stays locked after exceeding the threshold.
LOCKOUT_DURATION=15

# ---------------------------------------------------------------
# Session Timeouts (minutes)
# ---------------------------------------------------------------
# Admin accounts get a shorter timeout for security.
SESSION_TIMEOUT_ADMIN=30

# Regular user timeout (default 240 = 4 hours).
SESSION_TIMEOUT_DEFAULT=240

# When true, sessions stay alive for the duration of a Field Day event
# regardless of the timeout values above.
EVENT_DURATION_MODE=true

# ---------------------------------------------------------------
# Audit Logging
# ---------------------------------------------------------------
# Track login attempts, permission changes, and admin actions.
AUDIT_LOGGING_ENABLED=true

# How many days to keep audit log entries before pruning.
AUDIT_RETENTION_DAYS=365

# ---------------------------------------------------------------
# Password Requirements
# ---------------------------------------------------------------
# Minimum password length for regular users.
PASSWORD_MIN_LENGTH=8

# Minimum password length for admin accounts (stricter).
PASSWORD_ADMIN_MIN_LENGTH=12
